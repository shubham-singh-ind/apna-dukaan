# --- Database (PostgreSQL / Supabase) ---
# App runtime: use the Supabase *transaction pooler* (port 6543). Prisma REQUIRES
# `?pgbouncer=true` on a pooler URL or you get "prepared statement already exists".
# URL-encode any special chars in the password (e.g. `@` -> `%40`).
DATABASE_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# Migrations (`prisma db push` / `migrate`) need a DIRECT connection (port 5432),
# since the transaction pooler can't run them. Supabase -> Connect -> Direct connection.
# DIRECT_URL="postgresql://postgres:<password>@db.<ref>.supabase.co:5432/postgres"

# --- Admin auth (JWT) ---
# Generate a strong secret, e.g. `openssl rand -base64 32`
JWT_SECRET="change-me-in-production"
JWT_EXPIRES_IN="7d"

# --- Object storage (Supabase Storage) ---
# Shop photos are uploaded to a PUBLIC Supabase Storage bucket; the DB stores
# only the resulting public URL. Create a public bucket named to match
# SUPABASE_STORAGE_BUCKET in the Supabase dashboard (Storage -> New bucket).
SUPABASE_URL="https://<project-ref>.supabase.co"
# Service-role key (Supabase -> Settings -> API). Server-only; never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_STORAGE_BUCKET="shop-photos"

# --- App ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
